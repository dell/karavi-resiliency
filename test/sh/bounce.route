# By default, get all 'ensNNN' interfaces
route=""
seconds=240

for param in $*; do
  case $param in
  "--seconds")
    shift
    seconds=$1
    shift
    ;;
  "--route")
    shift
    route=$1
    shift
    ;;
  esac
done

echo "$(date +"%Y-%m-%d %H:%M:%S")" "-- invoking with seconds=$seconds route=$route" >>/root/bounce.route.out
ip route add $route/32 via 127.0.0.1

sleep $seconds
echo "$(date +"%Y-%m-%d %H:%M:%S")" -- done, going to renable interfaces >>/root/route.ip.out

ip route delete $route/32
ip route flush cache
